graph TD
    User["User (kubectl / Helm)"] -->|"create AutoScaler CR"| Operator

    subgraph Operator["AutoScaler Operator (Go)"]
        direction LR
        Validate["Validate RBG"] --> RBAC["Create RBAC"]
        RBAC --> Profile["Run Profiling"]
        Profile --> Deploy["Deploy Planner"]
    end

    Operator --> PJ["Profiling Job (Python)"]
    Operator --> Planner
    PJ -->|"writes"| CM["Profiling ConfigMap"]
    CM -->|"mounted"| Planner
    Prometheus["Prometheus"] -->|"PromQL"| Planner

    subgraph Planner["Planner Engine (Python)"]
        direction LR
        Adapter["Metrics Adapter<br/>sglang / vllm / dynamo"] --> Core["Scaling Logic<br/>predict &rarr; interpolate &rarr; scale"]
    end

    Planner -->|"scale via RBGSA"| RBG

    subgraph RBG["RoleBasedGroup"]
        direction LR
        Prefill["Prefill (N)"] ~~~ Decode["Decode (M)"]
    end

    style User fill:#555,stroke:#333,color:#fff
    style Operator fill:#4A90D9,stroke:#2C5F8A,color:#fff
    style Planner fill:#7B68EE,stroke:#5B48CE,color:#fff
    style Adapter fill:#9B59B6,stroke:#7D3C98,color:#fff
    style Core fill:#5DADE2,stroke:#2E86C1,color:#fff
    style PJ fill:#F5A623,stroke:#D4891A,color:#fff
    style CM fill:#50C878,stroke:#3AA85E,color:#fff
    style RBG fill:#E8E8E8,stroke:#999
    style Prometheus fill:#E6522C,stroke:#C4411E,color:#fff
